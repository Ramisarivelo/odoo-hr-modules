<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  LEAVE REQUEST VIEWS                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- ─── FORM VIEW ─────────────────────────────────────────────── -->
    <record id="view_lm_leave_request_form" model="ir.ui.view">
        <field name="name">lm.leave.request.form</field>
        <field name="model">lm.leave.request</field>
        <field name="arch" type="xml">
            <form string="Demande de Congé">
                <header>
                    <!-- ── Bouton Soumettre (Brouillon → En attente) -->
                    <button name="action_submit"
                            string="📤 Soumettre"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"
                            confirm="Êtes-vous sûr de vouloir soumettre cette demande ? Elle sera envoyée au manager pour approbation."/>

                    <!-- ── Boutons Manager : Approuver / Refuser -->
                    <button name="action_approve"
                            string="✅ Approuver"
                            type="object"
                            class="btn-success"
                            attrs="{'invisible': [('state', '!=', 'pending')]}"
                            groups="leave_management.group_leave_manager"
                            confirm="Confirmer l'approbation de cette demande de congé ?"/>

                    <button name="action_refuse"
                            string="❌ Refuser"
                            type="object"
                            class="btn-danger"
                            attrs="{'invisible': [('state', 'not in', ['pending', 'approved'])]}"
                            groups="leave_management.group_leave_manager"/>

                    <!-- ── Annuler -->
                    <button name="action_cancel"
                            string="🚫 Annuler"
                            type="object"
                            class="btn-warning"
                            attrs="{'invisible': [('state', 'not in', ['pending', 'approved'])]}"
                            confirm="Voulez-vous vraiment annuler cette demande de congé ?"/>

                    <!-- ── Remettre en brouillon -->
                    <button name="action_reset_draft"
                            string="🔄 Remettre en brouillon"
                            type="object"
                            attrs="{'invisible': [('state', 'not in', ['refused', 'cancelled'])]}"/>

                    <!-- ── Barre de statut -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,approved"
                           statusbar_colors='{"refused": "danger", "cancelled": "muted"}'/>
                </header>

                <sheet>
                    <!-- Alerte visuelle selon le statut -->
                    <div class="alert alert-success mb-3" role="alert"
                         attrs="{'invisible': [('state', '!=', 'approved')]}">
                        <strong>✅ Congé approuvé</strong> — Ce congé a été accordé.
                    </div>
                    <div class="alert alert-danger mb-3" role="alert"
                         attrs="{'invisible': [('state', '!=', 'refused')]}">
                        <strong>❌ Demande refusée</strong> —
                        <field name="refusal_reason" readonly="1" nolabel="1"/>
                    </div>
                    <div class="alert alert-warning mb-3" role="alert"
                         attrs="{'invisible': [('state', '!=', 'cancelled')]}">
                        <strong>🚫 Demande annulée.</strong>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <!-- Colonne gauche -->
                        <group string="Informations de la demande">
                            <field name="employee_id"
                                   attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="department_id" readonly="1"/>
                            <field name="leave_type_id"
                                   attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        </group>
                        <!-- Colonne droite -->
                        <group string="Période">
                            <field name="date_start"
                                   attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="date_end"
                                   attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="number_of_days" readonly="1"
                                   decoration-danger="number_of_days == 0"
                                   widget="integer"/>
                        </group>
                    </group>

                    <group string="Motif de la demande">
                        <field name="reason"
                               nolabel="1"
                               placeholder="Expliquez la raison de votre congé..."
                               attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                    </group>

                    <group string="Pièces jointes (certificat médical, etc.)"
                           attrs="{'invisible': [('state', '!=', 'draft')]}">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>

                    <!-- Informations d'approbation (lecture seule, visible si approuvé) -->
                    <group string="Traitement de la demande"
                           attrs="{'invisible': [('state', 'in', ['draft', 'pending'])]}">
                        <group>
                            <field name="approved_by" readonly="1"
                                   attrs="{'invisible': [('state', '!=', 'approved')]}"/>
                            <field name="approved_date" readonly="1"
                                   attrs="{'invisible': [('state', '!=', 'approved')]}"/>
                        </group>
                        <group>
                            <field name="refused_by" readonly="1"
                                   attrs="{'invisible': [('state', '!=', 'refused')]}"/>
                            <field name="refused_date" readonly="1"
                                   attrs="{'invisible': [('state', '!=', 'refused')]}"/>
                        </group>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── TREE VIEW ─────────────────────────────────────────────── -->
    <record id="view_lm_leave_request_tree" model="ir.ui.view">
        <field name="name">lm.leave.request.tree</field>
        <field name="model">lm.leave.request</field>
        <field name="arch" type="xml">
            <tree string="Demandes de congé"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'pending'"
                  decoration-danger="state == 'refused'"
                  decoration-muted="state in ('draft', 'cancelled')">
                <field name="reference" string="Référence"/>
                <field name="employee_id" string="Employé"/>
                <field name="department_id" string="Département"/>
                <field name="leave_type_id" string="Type"/>
                <field name="date_start" string="Début"/>
                <field name="date_end" string="Fin"/>
                <field name="number_of_days" string="Jours"/>
                <field name="submitted_date" string="Soumis le" optional="show"/>
                <field name="approved_by" string="Approuvé par" optional="hide"/>
                <field name="state" string="Statut" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'pending'"
                       decoration-danger="state == 'refused'"
                       decoration-info="state == 'draft'"
                       decoration-secondary="state == 'cancelled'"/>
                <!-- Actions rapides depuis la liste (manager uniquement) -->
                <button name="action_approve" type="object" string="✅ Approuver"
                        icon="fa-check" class="text-success"
                        attrs="{'invisible': [('state', '!=', 'pending')]}"
                        groups="leave_management.group_leave_manager"
                        confirm="Approuver cette demande ?"/>
                <button name="action_refuse" type="object" string="❌ Refuser"
                        icon="fa-times" class="text-danger"
                        attrs="{'invisible': [('state', 'not in', ['pending', 'approved'])]}"
                        groups="leave_management.group_leave_manager"/>
            </tree>
        </field>
    </record>

    <!-- ─── SEARCH VIEW ────────────────────────────────────────────── -->
    <record id="view_lm_leave_request_search" model="ir.ui.view">
        <field name="name">lm.leave.request.search</field>
        <field name="model">lm.leave.request</field>
        <field name="arch" type="xml">
            <search string="Rechercher une demande">
                <field name="reference" string="Référence"/>
                <field name="employee_id" string="Employé"/>
                <field name="leave_type_id" string="Type de congé"/>
                <field name="department_id" string="Département"/>
                <separator/>
                <!-- Filtres par statut -->
                <filter name="filter_draft"     string="📝 Brouillons"    domain="[('state', '=', 'draft')]"/>
                <filter name="filter_pending"   string="⏳ En attente"    domain="[('state', '=', 'pending')]"/>
                <filter name="filter_approved"  string="✅ Approuvés"     domain="[('state', '=', 'approved')]"/>
                <filter name="filter_refused"   string="❌ Refusés"       domain="[('state', '=', 'refused')]"/>
                <filter name="filter_cancelled" string="🚫 Annulés"       domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <!-- Filtres temporels -->
                <filter name="filter_this_month" string="Ce mois-ci"
                        domain="[('date_start', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <filter name="filter_upcoming" string="À venir"
                        domain="[('date_start', '&gt;=', context_today().strftime('%Y-%m-%d')), ('state', '=', 'approved')]"/>
                <!-- Groupby -->
                <group expand="1" string="Grouper par">
                    <filter name="group_state" string="Statut" context="{'group_by': 'state'}"/>
                    <filter name="group_employee" string="Employé" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_dept" string="Département" context="{'group_by': 'department_id'}"/>
                    <filter name="group_type" string="Type de congé" context="{'group_by': 'leave_type_id'}"/>
                    <filter name="group_month" string="Mois" context="{'group_by': 'date_start:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── ACTION WINDOW ─────────────────────────────────────────── -->
    <record id="action_lm_leave_request" model="ir.actions.act_window">
        <field name="name">Demandes de Congé</field>
        <field name="res_model">lm.leave.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_lm_leave_request_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune demande de congé pour le moment !
            </p>
            <p>
                Créez votre première demande de congé en cliquant sur "Nouveau".
            </p>
        </field>
    </record>

    <!-- Action : Mes demandes (vue employé) -->
    <record id="action_lm_my_leaves" model="ir.actions.act_window">
        <field name="name">Mes Demandes de Congé</field>
        <field name="res_model">lm.leave.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_lm_leave_request_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Vous n'avez pas encore de demande de congé !
            </p>
            <p>
                Cliquez sur "Nouveau" pour créer votre première demande.
            </p>
        </field>
    </record>

    <!-- Action : Demandes en attente (raccourci manager) -->
    <record id="action_lm_pending_leaves" model="ir.actions.act_window">
        <field name="name">Demandes en Attente d'Approbation</field>
        <field name="res_model">lm.leave.request</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
        <field name="search_view_id" ref="view_lm_leave_request_search"/>
        <field name="groups_id" eval="[(4, ref('leave_management.group_leave_manager'))]"/>
    </record>

</odoo>

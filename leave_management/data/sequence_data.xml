<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Séquence pour les références de congé -->
        <record id="seq_leave_request" model="ir.sequence">
            <field name="name">Séquence Demande de Congé</field>
            <field name="code">lm.leave.request</field>
            <field name="prefix">CONG/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>

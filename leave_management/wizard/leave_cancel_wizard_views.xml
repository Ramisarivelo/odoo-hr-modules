<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lm_leave_cancel_wizard_form" model="ir.ui.view">
        <field name="name">lm.leave.cancel.wizard.form</field>
        <field name="model">lm.leave.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Annuler des demandes de congé">
                <group string="Demandes concernées">
                    <field name="leave_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                </group>
                <group string="Options d'annulation">
                    <field name="notify_employees" widget="boolean_toggle"/>
                    <field name="cancellation_reason" required="1"
                           placeholder="Expliquez la raison de l'annulation (ex: urgence opérationnelle, réorganisation)..."/>
                </group>
                <footer>
                    <button name="action_confirm_cancel" type="object"
                            string="🚫 Confirmer l'annulation"
                            class="btn-warning" data-hotkey="q"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
